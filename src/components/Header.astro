---
import Button from './Button.astro';

type Locale = 'en' | 'ja';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props as Props;

const navigation = {
  en: {
    componentId: '1d782d06-8df0-b709-7aae-ca2a3e349dd0',
    wrapperId: undefined,
    home: { label: 'Home', href: '/' },
    products: { label: 'Products', href: '/products' },
    security: { label: 'Security', href: '/security-vuln' },
    contact: { label: 'Contact', href: '/contact' },
  },
  ja: {
    componentId: '69fd2859-5244-20c1-e0b8-bd1ba18f697b',
    wrapperId: '5f59c381-3a27-e2b7-faff-aac039f86576',
    home: { label: 'ホーム', href: '/ja/' },
    products: { label: '製品情報', href: '/ja/products' },
    security: { label: 'セキュリティ', href: '/ja/security-vuln' },
    contact: { label: 'お問い合わせ', href: '/ja/contact' },
  },
} as const;

const normalizePath = (path: string) => {
  let pathname = path.trim();

  if (/^[a-z][a-z\d+.-]*:\/\//i.test(pathname)) {
    pathname = new URL(pathname).pathname;
  } else {
    pathname = pathname.split(/[?#]/)[0];
  }

  pathname = `/${pathname.replace(/\\/g, '/').replace(/^\/+|\/+$/g, '')}`;
  pathname = pathname.replace(/\/{2,}/g, '/');

  pathname = pathname.replace(/\/index(?:\.html)?$/i, '') || '/';
  pathname = pathname.replace(/\.html$/i, '');

  if (/^\/home$/i.test(pathname)) return '/';
  if (/^\/ja(?:\/home)?$/i.test(pathname)) return '/ja';

  return pathname;
};

const nav = navigation[locale];
const normalizedCurrentPath = normalizePath(currentPath);
const langSwitchPath = locale === 'en'
  ? (normalizedCurrentPath === '/' ? '/ja/' : `/ja${normalizedCurrentPath}`)
  : (normalizedCurrentPath === '/ja' ? '/' : normalizedCurrentPath.replace(/^\/ja(?=\/)/, ''));

const languages = {
  en: {
    nativeLabel: 'English',
    englishLabel: 'English',
    flagAlt: 'US flag',
    flagSrc: '/images/us-flag.png'
  },
  ja: {
    nativeLabel: '日本語',
    englishLabel: 'Japanese (日本語)',
    // englishLabel: 'Japanese',
    flagAlt: 'Japan flag',
    flagSrc: '/images/jpn-flag.png',
  },
} as const;

const altLocale: Locale = locale === 'en' ? 'ja' : 'en';

const getLangOption = (langLocale: Locale) => {
  const language = languages[langLocale];

  return {
    ...language,
    label:
      locale === 'en'
        ? language.englishLabel
        : language.nativeLabel,
    href:
      langLocale === locale
        ? normalizedCurrentPath
        : langSwitchPath,
    selected: langLocale === locale,
  };
};

const currLang = getLangOption(locale);
const altLang = getLangOption(altLocale);
const langOptions = [currLang, altLang];

const langMenuLabel = locale === 'en' ? 'Select language' : '言語を選択';
const isCurrent = (href: string) => normalizedCurrentPath === normalizePath(href);
const currentClass = (href: string, baseClass: string) =>
  `${baseClass}${isCurrent(href) ? ' w--current' : ''}`;
const ariaCurrent = (href: string) => isCurrent(href) ? 'page' : undefined;
---

<header data-wf-component-id={nav.componentId} data-wf-variant-state="base" class="header">
  <div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar shadow-three w-nav">
    <div data-w-id={nav.wrapperId} class="navbar-wrapper">
      <a href={nav.home.href} aria-current={ariaCurrent(nav.home.href)} class={currentClass(nav.home.href, 'linked-nav-logo w-nav-brand')}>
        <img
          sizes={locale === 'en' ? '(max-width: 479px) 98vw, (max-width: 3344px) 100vw, 3344px' : '(max-width: 3344px) 100vw, 3344px'}
          srcset="/images/BMT-logo-blue-p-500.png 500w, /images/BMT-logo-blue-p-800.png 800w, /images/BMT-logo-blue-p-1080.png 1080w, /images/BMT-logo-blue-p-1600.png 1600w, /images/BMT-logo-blue-p-2000.png 2000w, /images/BMT-logo-blue-p-2600.png 2600w, /images/logo-blue.png 3344w"
          alt="logo"
          src="/images/logo-blue.png"
          class="navbar-logo"
        />
      </a>
      <nav role="navigation" class="nav-menu-wrapper w-nav-menu">
        <ul role="list" class="horiz-nav-menu w-list-unstyled">
          <li class="horiz-nav-item">
            <a href={nav.home.href} aria-current={ariaCurrent(nav.home.href)} class={currentClass(nav.home.href, 'nav-link')}>{nav.home.label}</a>
          </li>
          <li class="horiz-nav-item">
            <a href={nav.products.href} aria-current={ariaCurrent(nav.products.href)} class={currentClass(nav.products.href, 'nav-link')}>{nav.products.label}</a>
          </li>
          <li class="horiz-nav-item">
            <a href={nav.security.href} aria-current={ariaCurrent(nav.security.href)} class={currentClass(nav.security.href, 'nav-link')}>{nav.security.label}</a>
          </li>

          <!-- Desktop language selector -->
          <li class="horiz-nav-item language-menu" data-language-menu>
            <!-- v1: button + dropdown -->
            <button
              type="button"
              class="nav-link w-inline-block language-menu-trigger"
              data-language-trigger
              aria-label={langMenuLabel}
              aria-haspopup="menu"
              aria-expanded="false"
              aria-controls={`language-options-${locale}`}
            >
              <!-- <img src={currLang.flagSrc} width="20" height="13" alt={currLang.flagAlt} class="flag-icon"/> -->
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                width="18" 
                height="18" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="1.75" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                aria-hidden="true"
                class="lucide lucide-globe-icon lucide-globe language-menu-icon"
              >
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
                <path d="M2 12h20"/>
              </svg>
              <span>{currLang.label}</span>
              <svg class="language-menu-chevron" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6" /></svg>
            </button>
            <div id={`language-options-${locale}`} class="language-menu-options" data-language-options role="menu" hidden>
              {langOptions.map((language) => (
                <a
                  href={language.href}
                  class:list={['language-menu-option', { 'is-selected': language.selected }]}
                  role="menuitem"
                  aria-current={language.selected ? 'page' : undefined}
                >
                  <img src={language.flagSrc} width="20" height="13" alt={language.flagAlt} class="flag-icon"/>
                  <span>{language.label}</span>
                </a>
              ))}
            </div>

            <!-- v2: link -->
            <!-- <a href={altLang.href} class="nav-link w-inline-block">
              <img
                src={altLang.flagSrc}
                width="20"
                height="13"
                alt={altLang.flagAlt}
                class="flag-icon"
              />
              <span>{altLang.label}</span>
            </a> -->
          </li>

          <!-- Mobile language switcher -->
          <li class="horiz-nav-item mobile-language-link">
            <a href={altLang.href} class="nav-link w-inline-block">
              <img
                src={altLang.flagSrc}
                width="20"
                height="13"
                alt={altLang.flagAlt}
                class="flag-icon"
              />
              <span>{altLang.label}</span>
            </a>
          </li>
          <li class="nav-contact-button-wrap">
            <Button href={nav.contact.href} ariaCurrent={ariaCurrent(nav.contact.href)} class={isCurrent(nav.contact.href) ? 'w--current' : ''}>{nav.contact.label}</Button>
          </li>
        </ul>
      </nav>
      <div class="nav-right">
        <div class="div-block">
          <Button href={nav.contact.href} ariaCurrent={ariaCurrent(nav.contact.href)} class={isCurrent(nav.contact.href) ? 'w--current' : ''}>{nav.contact.label}</Button>
        </div>
        <div class="menu-button w-nav-button">
          <div class="icon-2 w-icon-nav-menu"></div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLElement>('[data-language-menu]').forEach((menu) => {
    const trigger = menu.querySelector<HTMLButtonElement>('[data-language-trigger]');
    const options = menu.querySelector<HTMLElement>('[data-language-options]');
    const links = Array.from(menu.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]'));

    if (!trigger || !options || links.length === 0) return;

    const close = (returnFocus = false) => {
      options.hidden = true;
      trigger.setAttribute('aria-expanded', 'false');
      if (returnFocus) trigger.focus();
    };
    const open = (focusIndex?: number) => {
      options.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      if (focusIndex !== undefined) links[focusIndex]?.focus();
    };
    const focusOption = (index: number) => links[(index + links.length) % links.length]?.focus();

    trigger.addEventListener('click', () => {
      if (options.hidden) open();
      else close();
    });

    trigger.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        open(0);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        open(links.length - 1);
      } else if (event.key === 'Escape') {
        close(true);
      }
    });

    options.addEventListener('keydown', (event) => {
      const currentIndex = links.indexOf(document.activeElement as HTMLAnchorElement);
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        focusOption(currentIndex + 1);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        focusOption(currentIndex - 1);
      } else if (event.key === 'Home') {
        event.preventDefault();
        focusOption(0);
      } else if (event.key === 'End') {
        event.preventDefault();
        focusOption(links.length - 1);
      } else if (event.key === 'Escape') {
        event.preventDefault();
        close(true);
      }
    });

    document.addEventListener('pointerdown', (event) => {
      if (event.target instanceof Node && !menu.contains(event.target)) close();
    });
    menu.addEventListener('focusout', () => {
      window.setTimeout(() => {
        if (!menu.contains(document.activeElement)) close();
      });
    });
  });
</script>
