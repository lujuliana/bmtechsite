---
import Layout from '../layouts/Layout.astro';
---

<Layout
  locale="en"
  title="Contact Us | BMTech"
  currentPath="/contact"
  description="Ready to build with BMTech? Contact our team directly for product inquiries, technical support, and more."
  ogTitle="Contact Us | BMTech"
  ogDescription="Ready to build with BMTech? Contact our team directly for product inquiries, technical support, and more."
  ogImage="https://cdn.prod.website-files.com/6a0c84e4593078e8f088bb7c/6a0fe4369f79f753573f39c8_8b94941eb69acb8d526938741fe02663_sign-gemini-trans.png"
  webflowPageId="6a1f15d68331060a67be7820"
>
  <Fragment slot="head">
    <style>html.w-mod-js:not(.w-mod-ix3) :is(.linked-nav-logo) {visibility: hidden !important;}</style>
  </Fragment>

  <Fragment slot="scripts">
    <script src="/js/contact-form.js" type="text/javascript"></script>
  </Fragment>

  <div class="main-wrapper">
    <section data-wf--banner--variant="overlay-dark" class="hero-section small">
      <div class="w-layout-blockcontainer hero-container w-container">
        <h1 data-w-id="cffab803-26ef-6867-3cb2-f5ad37876f0b" class="display-lg banner w-variant-2811ceda-65e0-7f4e-8038-b25febe7c0b4">Contact Us</h1>
      </div>
      <div class="overlay w-variant-2811ceda-65e0-7f4e-8038-b25febe7c0b4"></div><img src="/images/zbynek-burival-V4ZYJZJ3W4M-unsplash.jpg" loading="lazy" alt="A field of solar panels" class="image-2">
    </section>
    <div class="w-layout-blockcontainer container w-container">
      <div class="contact-wrap">
        <div class="contact-left">
          <h2 data-w-id="31f30811-b254-762b-b994-04dbeda6df14" style="opacity:0" class="contact-h2">Get in touch</h2>
          <p data-w-id="31f30811-b254-762b-b994-04dbeda6df16" style="opacity:0" class="body-txt gray">Have a question, interested in our products, or looking to collaborate? Fill out the form below or send an email, and our team will follow up with you shortly.</p>
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df28" style="opacity:0" class="contact-info-item _1st">
            <p class="contact-info-title">Headquarters</p>
            <p class="section-content">1255 W 15th St, Suite 325, Plano, TX 75075</p>
          </div>
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df2d" style="opacity:0" class="contact-info-item">
            <p class="contact-info-title">Email</p>
            <a href="mailto:info@bmtech.com?subject=Inquiry" class="section-content link">info@bmtech.com</a>
          </div>
          <!-- <div data-w-id="d1b609b2-14cf-2074-c3a7-c99485231387" style="opacity:0" class="contact-info-item">
            <p class="contact-info-title">Phone</p>
            <a href="" class="section-content link"></a>
          </div> -->
          <div class="contact-info-item">
            <p class="contact-info-title">Social media</p>
            <ul role="list" class="social-list">
              <li class="social-item">
                <a href="https://www.linkedin.com/company/battery-management-technology-corporation" target="_blank" rel="noopener noreferrer" class="social-link-two w-inline-block"><img src="/images/linkedin.svg" loading="lazy" alt="Icon" class="social-icon"></a>
              </li>
            </ul>
          </div>
          <a href="https://www.google.com/maps/place/1255+W+15th+St,+Plano,+TX+75075/" target="_blank" class="map-link-2 map-link w-inline-block"><img src="/images/map-md.png" loading="lazy" sizes="(max-width: 479px) 100vw, 511px" srcset="/images/a02cef54fca28df437cab64ae64b2a51_map-md-p-500.png 500w, /images/a02cef54fca28df437cab64ae64b2a51_map-md-p-800.png 800w, /images/map-md.png 923w" alt="Map" class="map-2 map"></a>
        </div>
        <div data-w-id="31f30811-b254-762b-b994-04dbeda6df32" style="opacity:0" class="form-main">
          <form id="email-form" name="email-form" action="https://r8gtx7aav7.execute-api.us-east-2.amazonaws.com/contact" method="post" class="form js-contact-form" data-locale="en">
            <div aria-hidden="true" style="position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden;"><label for="website">Website</label><input type="text" id="website" name="website" tabindex="-1" autocomplete="off"></div>
            <div class="single-block"><label for="name" class="input-label">Name *</label><input class="form-input w-input" maxlength="256" name="name" placeholder="e.g., John Doe" type="text" id="name" autocomplete="name" required></div>
            <div class="single-block"><label for="email" class="input-label">Email *</label><input class="form-input w-input" maxlength="256" name="email" placeholder="email@example.com" type="email" id="email" autocomplete="email" required></div>
            <div class="single-block"><label for="phone" class="input-label">Phone</label><input class="form-input w-input" maxlength="50" name="phone" placeholder="+1 (000) 000-0000" type="tel" id="phone" autocomplete="tel"></div>
            <div class="single-block"><label for="field" class="input-label">Subject *</label>
              <div class="form-input select"><select id="field" name="subject" required class="form-select w-select">
                  <option value="" disabled selected>Select an option</option>
                  <option value="Inquiry">Inquiry</option>
                  <option value="Career">Careers</option>
                  <option value="Security">Security or Vulnerability</option>
                  <option value="Other">Other</option>
                </select></div>
            </div>
            <div class="single-block"><label for="message" class="input-label">Message *</label><textarea required placeholder="Enter your message" minlength="10" maxlength="5000" id="message" name="message" class="form-input message w-input"></textarea></div><input type="submit" data-wait="Please wait..." class="btn-submit btn-primary w-button" value="Submit">
          </form>
          <div class="success-message" role="status" aria-live="polite" tabindex="-1" hidden>
            <div>Thank you! Your submission has been received.</div>
          </div>
          <div class="error-message" role="alert" aria-live="assertive" tabindex="-1" hidden>
            <div>Oops! Something went wrong while submitting the form.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
