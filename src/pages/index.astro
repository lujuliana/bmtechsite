              </a>
            </div>
          </div>
          <div class="prod-slide w-slide">
            <div data-w-id="0cdf2b58-3790-11ac-1196-dab7df62aa2f" class="prod-card">
              <a href="products/smc-gateway.html" class="link-card w-inline-block"><img loading="lazy" src="images/smc-gateway.jpg" alt="SMC-Gateway" sizes="(max-width: 800px) 100vw, 800px" srcset="images/smc-gateway-p-500.jpg 500w, images/smc-gateway.jpg 640w" class="card-img" />
