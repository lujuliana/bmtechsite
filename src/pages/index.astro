          <div class="prod-slide w-slide">
            <div data-w-id="0cdf2b58-3790-11ac-1196-dab7df62aa2f" class="prod-card">
              <a href="products/iot-b10.html" class="link-card w-inline-block"><img loading="lazy" src="images/IOT-B10.jpg" alt="IOT-B10" sizes="(max-width: 800px) 100vw, 800px" srcset="images/IOT-B10-p-500.jpg 500w, images/IOT-B10.jpg 560w" class="card-img" />
