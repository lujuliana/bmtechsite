---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import ProductCarousel from '../components/ProductCarousel.astro';
import { products, sortProductsBySlug } from '../data/products';

const homepageProducts = sortProductsBySlug(products.filter((product) => product.featured === true));
---

<Layout
  locale="en"
  title="Battery Management Technology Corporation"
  currentPath="/"
  description="Optimize your power infrastructure with BMTech. Discover our cutting-edge equipment and systems built for high-performance battery energy storage."
  ogTitle="Battery Management Technology Corporation"
  ogDescription="Optimize your power infrastructure with BMTech. Discover our cutting-edge equipment and systems built for high-performance battery energy storage."
  ogImage="/images/metal-sign.png"
  webflowPageId="6a0c84e6593078e8f088bc70"
>
  <Fragment slot="head">
    <style>html.w-mod-js:not(.w-mod-ix3) :is(.linked-nav-logo, .image-divider) {visibility: hidden !important;}</style>
  </Fragment>

  <Fragment slot="scripts">
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script>
  </Fragment>

  <div class="w-layout-vflex main-wrapper">
  <section class="hero-section">
    <div data-poster-url="videos/windfarm2-1_poster.0000000.jpg" data-video-urls="videos/windfarm2-1_mp4.mp4,videos/windfarm2-1_webm.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="hero-video w-background-video w-background-video-atom"><video id="68e50f0e-89e1-74b9-230c-fb6f5dbc2fd2-video" autoplay="" loop="" style="background-image:url(&quot;videos/windfarm2-1_poster.0000000.jpg&quot;)" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover">
        <source src="videos/windfarm2-1_mp4.mp4" data-wf-ignore="true">
        <source src="videos/windfarm2-1_webm.webm" data-wf-ignore="true">
      </video></div>
    <div class="overlay"></div>
    <div class="w-layout-blockcontainer hero-container w-container">
      <div data-w-id="ac31293e-530d-81d5-5877-184c410a707a" style="opacity:0" class="w-layout-blockcontainer hero-right w-container">
        <div class="hero-txt">Reliable energy management for a sustainable future.</div>
      </div>
      <div data-w-id="fc0af1aa-def5-3384-a861-1e7eab58edfa" style="opacity:0" class="w-layout-blockcontainer hero-left w-container">
        <h1 class="display-lg">Revolutionizing Energy Potential</h1>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="section-container">
      <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ec" style="opacity:0" class="section-col-aside">
        <img 
          class="section-col-img" 
          src="images/metal-sign.png" 
          alt="A metal sign reading: BMTech; empower a sustainable future" 
          style="opacity:0" 
          sizes="(max-width: 2093px) 100vw, 2093px" 
          srcset="images/metal-sign-500.png 500w, images/metal-sign-800.png 800w, images/metal-sign-1080.png 1080w, images/metal-sign-1600.png 1600w, images/metal-sign-2000.png 2000w, images/metal-sign.png 2093w" 
          loading="lazy" 
          data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ed" 
        />
      </div>
      <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ee" style="opacity:0" class="section-col-content">
        <h1 class="h1">Who We Are</h1>
        <p class="body-txt gray">
          Battery Management Technology Corporation (BMTech) is a Dallas, Texas-based cleantech company dedicated to advancing battery and energy management technologies. Since 2019, we have developed innovative solutions that support the growing demand for safe, reliable, and efficient energy storage.
        </p>
        <p class="body-txt gray">
          Our integrated hardware and software solutions help customers optimize battery performance, improve operational reliability, and maximize the value of their energy systems.
        </p>
      </div>
    </div>
    <div class="section-container">
      <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ee" style="opacity:0" class="section-col-content">
        <h1 class="h1">American Engineering, Global Impact</h1>
        <p class="body-txt gray">
          Built on American engineering principles, BMTech is committed to delivering high-quality, reliable technology backed by responsive technical expertise. We believe strong customer relationships are built through dependable products, practical engineering, and long-term support.
        </p>
      </div>
      <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ec" style="opacity:0" class="section-col-aside">
        <img 
          class="section-col-img" 
          src="images/texas-usa-flags.jpg" 
          alt="A metal sign reading: BMTech; empower a sustainable future" 
          style="opacity:0" 
          sizes="(max-width: 2093px) 100vw, 2093px" 
          loading="lazy" 
          data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ed" 
        />
      </div>
    </div>
  </section>
  <section class="image-divider">
    <div class="left-img-wrap"><img src="images/bess_compressed.jpeg" loading="lazy" sizes="(max-width: 1500px) 100vw, 1500px" srcset="images/bess_compressed-p-500.jpeg 500w, images/bess_compressed-p-800.jpeg 800w, images/bess_compressed-p-1080.jpeg 1080w, images/bess_compressed.jpeg 1500w" alt="A Battery Energy Storage System in the desert" class="image" /></div>
    <div data-poster-url="videos/solar-sky-poster.jpg" data-video-urls="videos/solar-sky.mp4,videos/solar-sky.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="background-video w-background-video w-background-video-atom"><video id="b6856f96-fb76-76a6-6ec9-9a81c2960e88-video" autoplay="" loop="" style="background-image:url(&quot;videos/solar-sky-poster.jpg&quot;)" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover">
        <source src="videos/solar-sky.mp4" data-wf-ignore="true">
        <source src="videos/solar-sky.webm" data-wf-ignore="true">
      </video></div>
  </section>
  <section data-w-id="78a9d919-15a5-2dad-8fd2-49055cbd634f" style="opacity:0" class="products-section">
    <div class="flex-container-y">
      <div class="flex-y">
        <h1 class="h1 centered">Products</h1>
        <p class="body-txt centered gray padding-bottom">Explore our Battery Management System (BMS) and Energy Management System (EMS) products.</p>
        <Button href="/products" variant="secondary">See All</Button>
      </div>
      <ProductCarousel
        id="homepage-products"
        products={homepageProducts}
        locale="en"
        label="Featured products"
        variant="homepage"
      />
    </div>
  </section>
  </div>
</Layout>
