>
  <Fragment slot="head">
    <meta content="Optimize your power infrastructure with BMTech. Discover our cutting-edge equipment and systems built for high-performance battery energy storage." name="description" />
    <meta content="Battery Management Technology Corporation" property="og:title" />
    <meta content="Optimize your power infrastructure with BMTech. Discover our cutting-edge equipment and systems built for high-performance battery energy storage." property="og:description" />
