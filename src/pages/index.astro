                  <h3 class="prod-card-name">BRMU</h3>
                  <p class="sm-txt gray-200 card">Battery Rack Management Unit</p>
                </div>
              </a>
            </div>
          </div>
          <div class="prod-slide w-slide">
            <div data-w-id="0cdf2b58-3790-11ac-1196-dab7df62aa2f" class="prod-card">
              <a href="products/ems-c.html" class="link-card w-inline-block"><img loading="lazy" src="images/ems-c.jpg" alt="EMS-C" sizes="(max-width: 800px) 100vw, 800px" srcset="images/ems-c-p-500.jpg 500w, images/ems-c.jpg 800w" class="card-img" />
                <div class="card-info">
