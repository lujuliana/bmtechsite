---
import ProductCard from '../components/ProductCard.astro';
import products from '../../data/products.json';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Product Card Preview</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Manrope:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/normalize.css" />
    <link rel="stylesheet" href="/css/webflow.css" />
    <link rel="stylesheet" href="/css/bmtechco.webflow.css" />

    <style>
      section:lang(ja),
      section:lang(ja) h1,
      section:lang(ja) h2,
      section:lang(ja) h3,
      section:lang(ja) h4,
      section:lang(ja) h5,
      section:lang(ja) h6 {
        font-family: var(--font-japanese);
      }

      section:lang(ja) {
        font-weight: var(--font-weight-regular);
      }
    </style>
  </head>
  <body>
    <main>
      <section>
        <h1>English</h1>
        <div class="w-layout-grid card-grid">
          {products.map((product) => <ProductCard product={product} locale="en" />)}
        </div>
      </section>

      <section lang="ja">
        <h2>日本語</h2>
        <div class="w-layout-grid card-grid">
          {products.map((product) => <ProductCard product={product} locale="ja" />)}
        </div>
      </section>
    </main>
  </body>
</html>
