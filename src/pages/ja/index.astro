---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import ProductCarousel from '../../components/ProductCarousel.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { products, sortProductsBySlug } from '../../data/products';

const homepageProducts = sortProductsBySlug(products.filter((product) => product.featured === true));
---

<Layout
  locale="ja"
  title="Battery Management Technology Corporation (日本)"
  currentPath="/ja/"
  description="BMTechで電力インフラを最適化。高性能なバッテリーエネルギー貯蔵システム向けに設計された、最先端の装置と製品システムを提供します。"
  ogTitle="Battery Management Technology Corporation (日本)"
  ogDescription="BMTechで電力インフラを最適化。高性能なバッテリーエネルギー貯蔵システム向けに設計された、最先端の装置と製品システムを提供します。"
  ogImage="/images/metal-sign.png"
  webflowPageId="6a0c84e6593078e8f088bc70"
>
  <Fragment slot="head">
    <style>html.w-mod-js:not(.w-mod-ix3) :is(.linked-nav-logo, .image-divider) {visibility: hidden !important;}</style>
  </Fragment>

  <Fragment slot="scripts">
    <script src="https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js" type="text/javascript"></script>
  </Fragment>

  <div class="w-layout-vflex main-wrapper">
    <section class="hero-section">
      <div data-poster-url="/videos/windfarm2-1_poster.0000000.jpg" data-video-urls="/videos/windfarm2-1_mp4.mp4,/videos/windfarm2-1_webm.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="hero-video w-background-video w-background-video-atom"><video id="68e50f0e-89e1-74b9-230c-fb6f5dbc2fd2-video" autoplay="" loop="" style="background-image:url(&quot;/videos/windfarm2-1_poster.0000000.jpg&quot;)" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover">
          <source src="/videos/windfarm2-1_mp4.mp4" data-wf-ignore="true">
          <source src="/videos/windfarm2-1_webm.webm" data-wf-ignore="true">
        </video></div>
      <div class="overlay"></div>
      <div class="w-layout-blockcontainer hero-container w-container">
        <div data-w-id="ac31293e-530d-81d5-5877-184c410a707a" class="w-layout-blockcontainer hero-right w-container">
          <div class="hero-txt">持続可能な未来のための、信頼できるエネルギー管理。</div>
        </div>
        <div data-w-id="fc0af1aa-def5-3384-a861-1e7eab58edfa" class="w-layout-blockcontainer hero-left w-container">
          <h1 class="display-lg">エネルギーの可能性を革新する</h1>
        </div>
      </div>
    </section>
    <section class="section">
      <div class="section-container">
        <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ec" class="section-col-aside"><img src="/images/metal-sign.png" loading="lazy" data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ed" sizes="(max-width: 2093px) 100vw, 2093px" alt="A metal sign reading: BMTech; empower a sustainable future" srcset="/images/metal-sign-500.png 500w, /images/metal-sign-800.png 800w, /images/metal-sign-1080.png 1080w, /images/metal-sign-1600.png 1600w, /images/metal-sign-2000.png 2000w, /images/metal-sign.png 2093w" class="section-col-img"></div>
        <div data-w-id="1d07c983-3d6a-4d3d-5bc9-d7fbce51e6ee" class="section-col-content">
          <h1 class="h1">私たちについて</h1>
          <p class="sm-txt gray-200">Battery Management Technology Corporation（BMTech）は、最先端のバッテリーマネジメントシステム（BMS）およびエネルギーマネジメントシステム（EMS）を専門とする、米国拠点のクリーンテック業界のリーダー企業です。2019年の創業以来、私たちは現代のエネルギーエコシステムが直面する複雑な課題に対応すべく、高性能なインフラストラクチャを開発・構築してまいりました。</p>
          <p class="sm-txt gray-200">革新的なソリューションの強固なポートフォリオを擁するBMTechは、世界中のクライアントに対し、バッテリー寿命の最適化、安全性の最大化、そして業務の効率化を実現する、セキュアかつインテリジェントで適応性の高いシステムを提供しています。</p>
        </div>
      </div>
    </section>
    <section class="image-divider">
      <div class="left-img-wrap"><img src="/images/bess_compressed.jpeg" loading="lazy" sizes="(max-width: 1500px) 100vw, 1500px" srcset="/images/bess_compressed-p-500.jpeg 500w, /images/bess_compressed-p-800.jpeg 800w, /images/bess_compressed-p-1080.jpeg 1080w, /images/bess_compressed.jpeg 1500w" alt="images/bess-solar.png" class="image"></div>
      <div data-poster-url="/videos/solar-sky-poster.jpg" data-video-urls="/videos/solar-sky.mp4,/videos/solar-sky.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="background-video w-background-video w-background-video-atom"><video id="b6856f96-fb76-76a6-6ec9-9a81c2960e88-video" autoplay="" loop="" style="background-image:url(&quot;/videos/solar-sky-poster.jpg&quot;)" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover">
          <source src="/videos/solar-sky.mp4" data-wf-ignore="true">
          <source src="/videos/solar-sky.webm" data-wf-ignore="true">
        </video></div>
    </section>
    <section data-w-id="78a9d919-15a5-2dad-8fd2-49055cbd634f" class="products-section">
      <div class="flex-container-y">
        <div class="flex-y">
          <SectionHeading title="製品情報" description="当社のバッテリー管理システム（BMS）およびエネルギー管理システム（EMS）製品をご覧ください。" centered />
          <Button href="/ja/products" variant="secondary">全て見る</Button>
        </div>
        <ProductCarousel
          id="homepage-products-ja"
          products={homepageProducts}
          locale="ja"
          label="注目製品"
          variant="homepage"
        />
      </div>
    </section>
  </div>
</Layout>
