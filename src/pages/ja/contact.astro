---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import PageBanner from '../../components/PageBanner.astro';
---

<Layout
  locale="ja"
  title="お問い合わせ | Contact"
  currentPath="/ja/contact"
  description="BMTechの製品で構築をはじめませんか？製品に関するお問い合わせ、技術サポートなどは、こちらから直接チームへご連絡ください。"
  ogTitle="お問い合わせ | Contact"
  ogDescription="BMTechの製品で構築をはじめませんか？製品に関するお問い合わせ、技術サポートなどは、こちらから直接チームへご連絡ください。"
  ogImage="/images/metal-sign.png"
  webflowPageId="6a1f15d68331060a67be7820"
>
  <Fragment slot="head">
    <style>html.w-mod-js:not(.w-mod-ix3) :is(.linked-nav-logo) {visibility: hidden !important;}</style>
  </Fragment>

  <Fragment slot="scripts">
    <script src="/js/contact-form.js" type="text/javascript"></script>
  </Fragment>

  <div class="main-wrapper">
    <PageBanner
      title="お問い合わせ"
      imageSrc="/images/solar-field.jpg"
      imageAlt="Solar panels in a field"
      imageSizes="(max-width: 1919px) 100vw, 1920px"
      imageSrcSet="/images/solar-field-p-500.jpg 500w, /images/solar-field-p-800.jpg 800w, /images/solar-field-p-1080.jpg 1080w, /images/solar-field-p-1600.jpg 1600w, /images/solar-field.jpg 1920w"
      sectionClass="hero-section small overlay-dark"
      containerClass="w-layout-blockcontainer hero-container overlay-dark-2 w-container"
      headingClass="display-lg banner"
      headingInitiallyHidden
      overlayClass="overlay overlay-dark-4"
      imageClass="image-2 overlay-dark-5"
    />
    <div class="w-layout-blockcontainer container w-container">
      <div class="contact-wrap">
        <div class="contact-left">
          <h2 data-w-id="31f30811-b254-762b-b994-04dbeda6df14" class="contact-h2">お気軽にご相談ください</h2>
          <p data-w-id="31f30811-b254-762b-b994-04dbeda6df16" class="body-txt gray">ご質問、製品に関するお問い合わせ、コラボレーションのご相談など、フォームまたはメールよりお気軽にご連絡ください。担当者より折り返しご連絡いたします。</p>
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df28" class="contact-info-item _1st">
            <p class="contact-info-title">本社</p>
            <p class="section-content">Suite 325, 1255 W 15th St<br>Plano, TX 75075, USA</p>
          </div>
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df2d" style="opacity:0" class="contact-info-item">
            <p class="contact-info-title">工場</p>
            <p class="section-content">Suite 103, 789 N Grover Rd<br>Richardson, TX 75081, USA</p>
          </div>
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df2d" class="contact-info-item">
            <p class="contact-info-title"><strong class="contact-info-title">メールアドレス</strong></p>
            <a href="mailto:info@bmtech.com?subject=Inquiry" class="section-content link">info@bmtech.com</a>
          </div>
          <!-- <div data-w-id="d1b609b2-14cf-2074-c3a7-c99485231387" class="contact-info-item">
            <p class="contact-info-title">電話番号</p>
            <a href="" class="section-content link"></a>
          </div> -->
          <div data-w-id="31f30811-b254-762b-b994-04dbeda6df2d" class="contact-info-item">
            <p class="contact-info-title">SNS</p>
            <ul role="list" class="social-list">
              <li class="social-item">
                <a href="https://www.linkedin.com/company/battery-management-technology-corporation" target="_blank" rel="noopener noreferrer" class="social-link-two w-inline-block"><img src="/images/linkedin.svg" loading="lazy" alt="Icon" class="social-icon"></a>
              </li>
            </ul>
          </div>
          <a data-w-id="31f30811-b254-762b-b994-04dbeda6df2d" href="https://www.google.com/maps/place/1255+W+15th+St,+Plano,+TX+75075/" target="_blank" rel="noopener noreferrer" class="map-link-2 map-link w-inline-block"><img src="/images/map-md.png" loading="lazy" sizes="(max-width: 923px) 100vw, 923px" srcset="/images/map-md-500.png 500w, /images/map-md-800.png 800w, /images/map-md.png 923w" alt="Map" class="map-2 map"></a>
        </div>
        <ContactForm locale="ja" />
      </div>
    </div>
  </div>
</Layout>
