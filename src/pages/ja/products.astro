---
import Layout from '../../layouts/Layout.astro';
import PageBanner from '../../components/PageBanner.astro';
import ProductCatalog from '../../components/ProductCatalog.astro';
import { products } from '../../data/products';
---

<Layout
  locale="ja"
  title="製品情報 | BMTech"
  currentPath="/ja/products"
  description="高性能なバッテリー電力およびエネルギー貯蔵インフラ向けに設計された、BMTechの最先端の製品とシステムをご覧いただけます。仕様はこちら。"
  ogTitle="製品情報 | BMTech"
  ogDescription="高性能なバッテリー電力およびエネルギー貯蔵インフラ向けに設計された、BMTechの最先端の製品とシステムをご覧いただけます。仕様はこちら。"
  ogImage="/images/metal-sign.png"
  webflowPageId="6a160510355148a0dbcd6f8c"
>
  <Fragment slot="head">
    <style>html.w-mod-js:not(.w-mod-ix3) :is(.linked-nav-logo) {visibility: hidden !important;}</style>
  </Fragment>

  <div class="main-wrapper">
    <PageBanner
      title="製品情報"
      webflowVariant="overlay-dark"
      imageSrc="/images/bess-gemini_compressed.png"
      imageAlt="A battery energy storage system next to a solar farm"
    />
    <section data-w-id="3017ba22-ff4d-07e5-212c-b5813f3244c8" class="w-layout-blockcontainer container w-container">
      <ProductCatalog products={products} locale="ja" />
    </section>
  </div>
</Layout>
